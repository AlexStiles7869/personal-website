---
layout: layouts/base.njk
title: Home
---
{% from "components/details.njk" import details %}

<div class="site-content is-layout-constrained" style="padding-top: var(--wp--preset--spacing--80); padding-bottom: var(--wp--preset--spacing--100);">
	
	<!-- Intro Block -->
	<div class="wp-block-group">
		<h1>Hi! I'm Alex</h1>
		<p class="has-large-font-size">{{ site.about }}</p>
		
		<div class="wp-block-buttons">
			<div class="wp-block-button">
				<a class="wp-element-button" href="#resume">
					View Resume
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
			</div>
			<div class="wp-block-button">
				<a class="wp-element-button is-style-outline" href="mailto:alex@example.com">Get in Touch</a>
			</div>
		</div>
	</div>

	<!-- Image Grid (alignwide) -->
	{# <div class="wp-block-group alignwide" style="margin-top: var(--wp--preset--spacing--100); margin-bottom: var(--wp--preset--spacing--100);">
		<div class="pswp-gallery">
			<!-- Large Image -->
			<figure class="wp-block-image" style="margin-bottom: var(--wp--preset--spacing--50);">
				<a href="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=2400&h=1200&fit=crop" class="pswp-link" data-pswp-width="2400" data-pswp-height="1200" target="_blank">
					<img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=1200&h=600&fit=crop" 
						 alt="Workspace 1" 
						 class="grid-image-large"
						 width="1200" height="600"
						 sizes="(min-width: 820px) 818px, 100vw"
						 loading="eager">
				</a>
				<figcaption>Building distributed systems at CBA.</figcaption>
			</figure>
			
			<!-- Two Smaller Images side by side -->
			<div class="wp-block-columns" style="margin-bottom: 0;">
				<div class="wp-block-column">
					<figure class="wp-block-image">
						<a href="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=2000&h=1500&fit=crop" class="pswp-link" data-pswp-width="2000" data-pswp-height="1500" target="_blank">
							<img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=600&h=450&fit=crop" 
								 alt="Code snippet" 
								 class="grid-image"
								 width="600" height="450"
								 sizes="(min-width: 820px) 400px, 50vw">
						</a>
						<figcaption class="individual-caption">System architecture design.</figcaption>
					</figure>
				</div>
				<div class="wp-block-column">
					<figure class="wp-block-image">
						<a href="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=2000&h=1500&fit=crop" class="pswp-link" data-pswp-width="2000" data-pswp-height="1500" target="_blank">
							<img src="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=600&h=450&fit=crop" 
								 alt="Laptop on desk" 
								 class="grid-image"
								 width="600" height="450"
								 sizes="(min-width: 820px) 400px, 50vw">
						</a>
						<figcaption class="individual-caption">Real-time data visualization.</figcaption>
					</figure>
				</div>
			</div>
			<!-- Grid Wide Caption (only visible on mobile) -->
			<div class="grid-wide-caption">Architecture and data visualizations.</div>
		</div>
	</div> #}

	<!-- Resume Section -->
	<div id="resume" class="wp-block-group" style="margin-top: var(--wp--preset--spacing--100); border-top: 1px solid var(--wp--preset--color--contrast-5); padding-top: var(--wp--preset--spacing--80);">
		<h2 class="has-system-sans-serif-font-family has-contrast-2-color" style="font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 0; margin-bottom: var(--wp--preset--spacing--60);">Work Experience</h2>
		
		{% for job in resume.workExperience %}
		<div class="wp-block-columns resume-item" {% if not loop.last %}style="margin-bottom: var(--wp--preset--spacing--80);"{% endif %}>
			<div class="wp-block-column" style="flex-basis: 30%;">
				<p class="has-contrast-2-color" style="margin-top: 0; margin-bottom: 8px; font-size: var(--wp--preset--font-size--x-small); font-weight: 400;">{{ job.period }} &middot; {{ job.location }}</p>
				<p style="margin-top: 0; margin-bottom: 8px; font-size: var(--wp--preset--font-size--small); font-weight: 600; color: var(--wp--preset--color--contrast); line-height: 1.2;">{{ job.role }}</p>
				<p class="has-contrast-2-color" style="margin-top: 0; margin-bottom: 0; font-size: var(--wp--preset--font-size--x-small); font-weight: 500; line-height: 1.4;">{{ job.company }}</p>
			</div>
			<div class="wp-block-column">
				<div class="resume-content">
					<p>{{ job.description }}</p>
					
					{% if job.portraitImages %}
					<div class="wp-block-columns pswp-gallery" style="margin-top: var(--wp--preset--spacing--40); margin-bottom: 0;">
						{% for img in job.portraitImages %}
						<div class="wp-block-column">
							<a href="{{ img }}?w=1500&h=2000&fit=crop" class="pswp-link" data-pswp-width="1500" data-pswp-height="2000" target="_blank">
								<img src="{{ img }}?w=600&h=800&fit=crop" 
									 alt="{{ job.company }}" 
									 class="grid-image-portrait"
									 width="600" height="800"
									 sizes="(min-width: 600px) 260px, 33vw">
							</a>
						</div>
						{% endfor %}
					</div>
					{% endif %}

					{% if job.images %}
						{% call details("View Project Images") %}
							<div class="wp-block-group pswp-gallery">
								<!-- Large Image -->
								<figure class="wp-block-image" style="margin-bottom: var(--wp--preset--spacing--50);">
									<a href="{{ job.images[0] }}?w=2400&h=1200&fit=crop" class="pswp-link" data-pswp-width="2400" data-pswp-height="1200" target="_blank">
										<img src="{{ job.images[0] }}?w=1200&h=600&fit=crop" 
											 alt="{{ job.company }}" 
											 class="grid-image-large"
											 width="1200" height="600"
											 sizes="(min-width: 600px) 600px, 100vw">
									</a>
									<figcaption>Platform architectural visualization.</figcaption>
								</figure>
								
								<!-- Two Smaller Images -->
								<div class="wp-block-columns" style="margin-bottom: 0;">
									<div class="wp-block-column">
										<a href="{{ job.images[1] }}?w=2000&h=1500&fit=crop" class="pswp-link" data-pswp-width="2000" data-pswp-height="1500" target="_blank">
											<img src="{{ job.images[1] }}?w=600&h=450&fit=crop" 
												 alt="{{ job.company }}" 
												 class="grid-image"
												 width="600" height="450"
												 sizes="(min-width: 600px) 300px, 50vw">
										</a>
									</div>
									<div class="wp-block-column">
										<a href="{{ job.images[2] }}?w=2000&h=1500&fit=crop" class="pswp-link" data-pswp-width="2000" data-pswp-height="1500" target="_blank">
											<img src="{{ job.images[2] }}?w=600&h=450&fit=crop" 
												 alt="{{ job.company }}" 
												 class="grid-image"
												 width="600" height="450"
												 sizes="(min-width: 600px) 300px, 50vw">
										</a>
									</div>
								</div>
							</div>
						{% endcall %}
					{% endif %}
				</div>
			</div>
		</div>
		{% endfor %}
	</div>
</div>
