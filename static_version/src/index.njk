---
layout: layouts/base.njk
title: Home
---
{% from "components/details.njk" import details %}

<div class="site-content is-layout-constrained" style="padding-top: var(--wp--preset--spacing--80); padding-bottom: var(--wp--preset--spacing--100);">
	
	<!-- Intro Block -->
	<div class="wp-block-group">
		<h1>Hi! I'm Alex</h1>
		<p class="has-large-font-size">{{ site.about }}</p>
		
		<div class="wp-block-buttons" style="display: flex; flex-wrap: wrap; gap: 1em; width: max-content; max-width: 100%;">
			<div class="wp-block-button" style="flex: 1 1 auto;">
				{% if flags.resumeButton == false %}
				<a class="wp-element-button" style="opacity: 0.5; pointer-events: none; cursor: default; -webkit-user-select: none; user-select: none; width: 100%; display: flex; justify-content: center; align-items: center; gap: 8px; box-sizing: border-box;">
					<span>View Resume</span>
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10L12 15L17 10 M12 15V3" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
				{% else %}
				<a class="wp-element-button" href="#resume" style="-webkit-user-select: none; user-select: none; width: 100%; display: flex; justify-content: center; align-items: center; gap: 8px; box-sizing: border-box;">
					<span>View Resume</span>
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10L12 15L17 10 M12 15V3" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
				{% endif %}
			</div>
			<div class="wp-block-button" style="flex: 1 1 auto;">
				<a class="wp-element-button is-style-outline" href="mailto:me@alexstiles.me" style="-webkit-user-select: none; user-select: none; width: 100%; display: flex; justify-content: center; align-items: center; gap: 8px; box-sizing: border-box;">
					<span>Get in Touch</span>
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
			</div>
		</div>
	</div>

	<!-- Image Grid (alignwide) -->
	{# <div class="wp-block-group alignwide" style="margin-top: var(--wp--preset--spacing--100); margin-bottom: var(--wp--preset--spacing--100);">
		<div class="pswp-gallery">
			<!-- Large Image -->
			<figure class="wp-block-image" style="margin-bottom: var(--wp--preset--spacing--50);">
				<a href="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=2400&h=1200&fit=crop" class="pswp-link" data-pswp-width="2400" data-pswp-height="1200" target="_blank">
					<img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=1200&h=600&fit=crop" 
						 alt="Workspace 1" 
						 class="grid-image-large"
						 width="1200" height="600"
						 sizes="(min-width: 820px) 818px, 100vw"
						 loading="eager">
				</a>
				<figcaption>Building distributed systems at CBA.</figcaption>
			</figure>
			
			<!-- Two Smaller Images side by side -->
			<div class="wp-block-columns" style="margin-bottom: 0;">
				<div class="wp-block-column">
					<figure class="wp-block-image">
						<a href="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=2000&h=1500&fit=crop" class="pswp-link" data-pswp-width="2000" data-pswp-height="1500" target="_blank">
							<img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=600&h=450&fit=crop" 
								 alt="Code snippet" 
								 class="grid-image"
								 width="600" height="450"
								 sizes="(min-width: 820px) 400px, 50vw">
						</a>
						<figcaption class="individual-caption">System architecture design.</figcaption>
					</figure>
				</div>
				<div class="wp-block-column">
					<figure class="wp-block-image">
						<a href="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=2000&h=1500&fit=crop" class="pswp-link" data-pswp-width="2000" data-pswp-height="1500" target="_blank">
							<img src="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=600&h=450&fit=crop" 
								 alt="Laptop on desk" 
								 class="grid-image"
								 width="600" height="450"
								 sizes="(min-width: 820px) 400px, 50vw">
						</a>
						<figcaption class="individual-caption">Real-time data visualization.</figcaption>
					</figure>
				</div>
			</div>
			<!-- Grid Wide Caption (only visible on mobile) -->
			<div class="grid-wide-caption">Architecture and data visualizations.</div>
		</div>
	</div> #}

	<!-- Resume Section -->
	<div id="resume" class="wp-block-group" style="margin-top: var(--wp--preset--spacing--100); border-top: 1px solid var(--wp--preset--color--contrast-5); padding-top: var(--wp--preset--spacing--80);">
		<h2 class="has-system-sans-serif-font-family has-contrast-2-color" style="font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 0; margin-bottom: var(--wp--preset--spacing--60);">Work Experience</h2>
		
		{% set sortedResume = collections.resume | sort(true, false, 'date') %}
		{% for job in sortedResume %}
		<div class="wp-block-columns resume-item" {% if not loop.last %}style="margin-bottom: var(--wp--preset--spacing--80);"{% endif %}>
			<div class="wp-block-column" style="flex-basis: 30%;">
				<p class="has-contrast-2-color" style="margin-top: 0; margin-bottom: 8px; font-size: var(--wp--preset--font-size--x-small); font-weight: 400; line-height: 1.4;">{{ job.data.period | replace(" / ", " &middot; <br>") | safe }} &middot; <br>{{ job.data.location }}</p>
				<p style="margin-top: 0; margin-bottom: 8px; font-size: var(--wp--preset--font-size--small); font-weight: 600; color: var(--wp--preset--color--contrast); line-height: 1.2;">{{ job.data.role }}</p>
				<p class="has-contrast-2-color" style="margin-top: 0; margin-bottom: 0; font-size: var(--wp--preset--font-size--x-small); font-weight: 500; line-height: 1.4;">{{ job.data.company }}</p>
			</div>
			<div class="wp-block-column">
				{% set isExpandable = "[[MORE]]" in job.content %}
				<div class="resume-content {% if isExpandable %}is-expandable{% endif %}">
					{% if isExpandable %}
						<div class="blurb">
							{{ job.content | beforeMore | safe }}
						</div>
						<div class="expandable-trigger-wrapper" style="margin-top: 10px;">
							<button class="read-more-trigger" aria-expanded="false" style="background: none; border: none; padding: 0; color: var(--wp--preset--color--contrast-2); font-family: var(--wp--preset--font-family--system-sans-serif); font-size: 13px; font-weight: 500; cursor: pointer; display: flex; align-items: center; gap: 4px; transition: color 0.2s ease;">
								<span class="trigger-text">Read More</span>
								<svg class="trigger-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="transition: transform 0.3s ease;">
									<path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
							</button>
						</div>
						<div class="expand-content-inner" style="height: 0; overflow: hidden;">
							<div class="expand-content-padding" style="padding-top: 4px;">
								{{ job.content | afterMore | safe }}
							</div>
						</div>
					{% else %}
						{{ job.content | safe }}
					{% endif %}
				</div>
			</div>
		</div>
		{% endfor %}
	</div>
</div>
