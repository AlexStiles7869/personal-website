<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{{ title }} | {{ site.title }}</title>
	
	<!-- Preload Fonts -->
	<link rel="preload" href="/assets/fonts/newsreader/newsreader-var.woff2" as="font" type="font/woff2" crossorigin>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
	
	<link rel="stylesheet" href="/assets/css/main.css">
	
	<!-- PhotoSwipe Core CSS -->
	<link rel="stylesheet" href="https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.css">

	<!-- GSAP for premium motion -->
	<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
</head>
<body>
	{% include "header.njk" %}

	<main>
		{{ content | safe }}
	</main>

	{% include "footer.njk" %}

	<!-- PhotoSwipe Initialization -->
	<script type="module">
		import PhotoSwipeLightbox from 'https://unpkg.com/photoswipe@5.4.3/dist/photoswipe-lightbox.esm.js';
		
		const lightbox = new PhotoSwipeLightbox({
			gallery: '.pswp-gallery',
			children: 'a.pswp-link',
			pswpModule: () => import('https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.esm.js')
		});

		// Remote Image Aspect Ratio Fix:
		// Since remote images don't go through Eleventy's build process, we don't know their 
		// dimensions at build time. PhotoSwipe needs these to prevent "smushing".
		// We calculate the ratio from the thumbnail and set large virtual dimensions 
		// to allow PhotoSwipe to scale the image up to fill the screen.
		const updateDims = (img) => {
			const link = img.closest('a.pswp-link');
			if (link && img.naturalWidth && img.naturalHeight) {
				const ratio = img.naturalWidth / img.naturalHeight;
				// Use the max of window dimensions as the target long edge
				const targetLongEdge = Math.max(window.innerWidth, window.innerHeight) * window.devicePixelRatio;
				
				if (ratio > 1) {
					// Landscape
					link.setAttribute('data-pswp-width', Math.round(targetLongEdge));
					link.setAttribute('data-pswp-height', Math.round(targetLongEdge / ratio));
				} else {
					// Portrait
					link.setAttribute('data-pswp-height', Math.round(targetLongEdge));
					link.setAttribute('data-pswp-width', Math.round(targetLongEdge * ratio));
				}
			}
		};

		document.querySelectorAll('.pswp-gallery img').forEach(img => {
			if (img.complete) updateDims(img);
			else img.addEventListener('load', () => updateDims(img));
		});
		
		lightbox.init();
	</script>

	<!-- Resume Expandable Logic -->
	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const triggers = document.querySelectorAll('.read-more-trigger');

			triggers.forEach(trigger => {
				trigger.addEventListener('click', () => {
					const container = trigger.closest('.is-expandable');
					const inner = container.querySelector('.expand-content-inner');
					const text = trigger.querySelector('.trigger-text');
					const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

					// Immediate UI feedback
					trigger.setAttribute('aria-expanded', !isExpanded);
					text.textContent = isExpanded ? 'Read More' : 'Read Less';

					if (!isExpanded) {
						// Expand
						gsap.to(inner, {
							height: 'auto',
							duration: 0.4,
							ease: 'power2.out'
						});
					} else {
						// Collapse
						gsap.to(inner, {
							height: 0,
							duration: 0.3,
							ease: 'power2.inOut'
						});
					}
				});
			});

			/* --- Arrow Conveyor Logic (GSAP) --- */
			const arrowParents = document.querySelectorAll('.external-link, .wp-element-button');
			
			const animateLoop = (el, type) => {
				if (el._isAnimating) return;
				el._isAnimating = true;

				const container = el.querySelector('.icon-loop');
				const primary = container?.querySelector('svg:not(.icon-clone)');
				const clone = container?.querySelector('.icon-clone');
				
				// Special case: Download arrow (South)
				const dlPrimary = el.querySelector('.dl-arrow-primary');
				const dlClone = el.querySelector('.dl-arrow-clone');

				const tl = gsap.timeline({
					onComplete: () => { el._isAnimating = false; }
				});

				const ease = "power2.inOut";

				if (type === 'ne' && primary && clone) {
					gsap.set(primary, { xPercent: 0, yPercent: 0, force3D: false });
					gsap.set(clone, { visibility: 'visible', xPercent: -100, yPercent: 100, force3D: false });
					tl.to(primary, { xPercent: 100, yPercent: -100, duration: 0.5, ease });
					tl.to(clone, { xPercent: 0, yPercent: 0, duration: 0.5, ease }, 0);
				} else if (type === 'e' && primary && clone) {
					gsap.set(primary, { xPercent: 0, yPercent: 0, force3D: false });
					gsap.set(clone, { visibility: 'visible', xPercent: -100, yPercent: 0, force3D: false });
					tl.to(primary, { xPercent: 100, yPercent: 0, duration: 0.5, ease });
					tl.to(clone, { xPercent: 0, yPercent: 0, duration: 0.5, ease }, 0);
				} else if (type === 's' && dlPrimary && dlClone) {
					gsap.set(dlPrimary, { y: 0, force3D: false });
					tl.to(dlPrimary, { y: 24, duration: 0.4, ease });
					tl.fromTo(dlClone, { y: -24, force3D: false }, { y: 0, duration: 0.4, ease }, 0);
				}
			};

			arrowParents.forEach(parent => {
				parent.addEventListener('mouseenter', () => {
					if (parent.querySelector('.icon-loop--ne')) animateLoop(parent, 'ne');
					else if (parent.querySelector('.icon-loop--e')) animateLoop(parent, 'e');
					else if (parent.querySelector('.dl-arrow-primary')) animateLoop(parent, 's');
				});
			});
		});
	</script>
</body>
</html>
