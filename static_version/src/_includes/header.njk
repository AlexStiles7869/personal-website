<header style="border-bottom: 1px solid var(--wp--preset--color--contrast-5);">
	<div class="site-content is-layout-constrained" style="padding-top: var(--wp--preset--spacing--60); padding-bottom: var(--wp--preset--spacing--60);">
		<div class="wp-block-columns is-not-stacked-on-mobile" style="gap: var(--wp--preset--spacing--50); margin-bottom: 0;">
			
			<div class="wp-block-column is-vertically-aligned-stretch">
				<div style="display: flex; flex-direction: column; gap: var(--wp--preset--spacing--40);">
					
					<div style="display: flex; flex-direction: column; gap: var(--wp--preset--spacing--10);">
						<h1 class="wp-block-site-title"><a href="/" style="text-decoration: none; color: inherit;">{{ site.title }}</a></h1>
						<p class="wp-block-site-tagline">{{ site.tagline }}</p>
					</div>

					<nav class="nav-pill-container has-system-sans-serif-font-family">
						<div class="nav-pill-background" id="nav-pill-bg"></div>
						<ul class="nav-pill-list">
							{% for item in site.navigation %}
							{% set isCurrent = (page.url == item.url) %}
							{% set isBlog = (item.url == '/blog/') %}
							{% if isBlog and flags.blogPage == false %}
							<li class="nav-pill-item" style="pointer-events: none;">
								<span class="nav-link" style="cursor: default;">
									{{ item.label }}
								</span>
							</li>
							{% else %}
							<li class="nav-pill-item" {% if isCurrent %}data-active="true"{% endif %}>
								<a href="{{ item.url }}" class="nav-link" {% if isCurrent %}aria-current="page"{% endif %}>
									{{ item.label }}
								</a>
							</li>
							{% endif %}
							{% endfor %}
						</ul>
					</nav>
					
					<style>
						.nav-pill-container {
							position: relative;
							display: inline-flex;
							width: max-content;
							align-self: flex-start;
							background: rgba(128, 128, 128, 0.1); 
							border: 1px solid rgba(128, 128, 128, 0.15); 
							backdrop-filter: blur(12px);
							-webkit-backdrop-filter: blur(12px);
							padding: 4px;
							border-radius: 9999px;
						}

						.nav-pill-list {
							display: flex;
							list-style: none;
							padding: 0;
							margin: 0;
							gap: 0;
							position: relative;
							z-index: 1;
						}

						.nav-pill-item {
							position: relative;
							z-index: 2;
						}

						.nav-pill-item .nav-link {
							display: block;
							padding: 8px 20px;
							color: var(--wp--preset--color--contrast);
							text-decoration: none;
							font-weight: 500;
							font-size: 0.85rem;
							border-radius: 9999px;
							transition: opacity 0.3s ease;
							line-height: 1;
							opacity: 0.5;
							-webkit-user-select: none;
							user-select: none;
						}

						/* Active/Hover states */
						.nav-pill-container:not(:has(.nav-pill-item:hover)) .nav-pill-item[data-active="true"] .nav-link,
						.nav-pill-item:hover .nav-link {
							opacity: 1;
						}


						.nav-pill-background {
							position: absolute;
							box-sizing: border-box;
							top: 4px;
							bottom: 4px;
							left: 0;
							width: 0;
							background: rgba(128, 128, 128, 0.2); 
							border: 1px solid rgba(128, 128, 128, 0.25); 
							border-radius: 9999px;
							opacity: 0; 
							z-index: 0;
							pointer-events: none;
							will-change: transform, width;
						}
					</style>

					<script>
					document.addEventListener('DOMContentLoaded', () => {
						const container = document.querySelector('.nav-pill-container');
						const bg = document.getElementById('nav-pill-bg');
						const items = document.querySelectorAll('.nav-pill-item');
						let activeItem = document.querySelector('.nav-pill-item[data-active="true"]') || items[0];

						if (!container || !bg || !window.gsap) return;
						
						const updatePill = (elem, animate = true) => {
							if (!elem) return;
							
							const containerRect = container.getBoundingClientRect();
							const elemRect = elem.getBoundingClientRect();
							const left = elemRect.left - containerRect.left;
							const width = elemRect.width;
							
							if (!animate) {
								// Instant snap for "perfect immediate display"
								gsap.set(bg, { 
									x: left, 
									width: width, 
									opacity: 1 
								});
							} else {
								// Premium weighted motion
								gsap.to(bg, {
									x: left,
									width: width,
									duration: 0.4,
									ease: "expo.out",
									overwrite: "auto"
								});
							}
						};

						// Initial snap (no animation) to ensure "perfect immediate display"
						updatePill(activeItem, false);

						// Pixel-perfection finalize after fonts load
						if (document.fonts) {
							document.fonts.ready.then(() => {
								updatePill(activeItem, false);
							});
						}

						// Detect touch-primary devices via genuine touchstart (never synthesized for mouse).
						// We gate ALL GSAP animations with this — mobile gets zero hover animation.
						let isTouchDevice = false;
						window.addEventListener('touchstart', () => { isTouchDevice = true; }, { once: true, passive: true });

						items.forEach(item => {
							item.addEventListener('mouseenter', () => {
								if (isTouchDevice) return;
								updatePill(item);
							});
						});

						container.addEventListener('mouseleave', () => {
							if (isTouchDevice) return;
							updatePill(activeItem);
						});

						window.addEventListener('resize', () => {
							const hovered = container.querySelector('.nav-pill-item:hover');
							updatePill(hovered || activeItem, false);
						});
					});
					</script>

				</div>
			</div>

			{# 
			<div class="wp-block-column" style="flex-basis: 128px; flex-grow: 0; display: flex; justify-content: flex-end;">
				<img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=256&h=256&fit=crop" style="width: 128px; height: 128px; object-fit: cover; border-radius: 50%; background: var(--wp--preset--color--contrast-5);" alt="Profile Photo">
			</div>
			#}

		</div>
	</div>
</header>
